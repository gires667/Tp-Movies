{
  "name": "node-ts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch --env-file=.env src/Movie/server.ts",
    "typecheck": "tsc --watch --pretty --noEmit",
    "sandbox": "tsx watch src/sandbox/index.ts",
    "exo": "tsx watch src/sandbox/exo.ts",
    "cart": "tsx watch src/cart/application/index.ts",
    "test": "vitest",
    "movie": "tsx watch --env-file=.env src/Movie/server.ts",
    "drizzle:push": "npx drizzle-kit push"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.18.0",
    "zod": "^4.3.6"
  }
}
